# Firebase web config (public identifiers — safe in the client bundle, but kept
# out of source to avoid secret-scanner noise). Copy to `.env` and fill in from
# Firebase console → Project settings → Your apps → Web app → SDK config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Cloud Messaging → Web Push certificates → key pair (public VAPID key)
VITE_FIREBASE_VAPID_KEY=
# App Check → reCAPTCHA v3 site key (public)
VITE_RECAPTCHA_SITE_KEY=
