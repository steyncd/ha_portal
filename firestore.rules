rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bootstrap owners: always allowed as owners, even before settings/access
    // exists, so the first sign-in works and can seed the list. Keep in sync
    // with BOOTSTRAP_OWNERS in src/lib/auth.svelte.ts.
    function bootstrap() {
      return request.auth != null
        && request.auth.token.email in [
          'christosteyn@cloudbadger.com',
          'steyncd@gmail.com'
        ];
    }
    function accessExists() {
      return exists(/databases/$(database)/documents/settings/access);
    }
    function accessData() {
      return get(/databases/$(database)/documents/settings/access).data;
    }
    function isOwner() {
      return request.auth != null && (
        bootstrap() ||
        (accessExists() && request.auth.token.email in accessData().owners)
      );
    }
    function isMember() {
      return isOwner() ||
        (request.auth != null && accessExists()
         && request.auth.token.email in accessData().members);
    }
    // Guests: signed in + listed in access.guests, but NOT a member. They get a
    // forced, restricted view (client-enforced by role) and read-only Firestore
    // limited to what the app needs to boot (access doc + HA connection).
    function isGuest() {
      return request.auth != null && accessExists()
        && !isMember()
        && request.auth.token.email in accessData().guests;
    }
    function isAllowed() { return isMember() || isGuest(); }

    // Access list: members + guests read (guests need it to learn their role +
    // allowed views); owners manage.
    match /settings/access {
      allow read: if isAllowed();
      allow write: if isOwner();
    }

    // HA connection token: guests need it to open the live WebSocket; members write.
    match /settings/haConnection {
      allow read: if isAllowed();
      allow write: if isMember();
    }

    // Per-user profile: any allowed user reads; only the doc's owner writes.
    match /profiles/{uid} {
      allow read: if isAllowed();
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Access log: allowed users append their own events; owners read + prune.
    match /access_log/{id} {
      allow read: if isOwner();
      allow create: if isAllowed()
        && request.resource.data.email == request.auth.token.email.lower();
      allow update, delete: if isOwner();
    }

    // Everything else (logged data, messages, etc.): household members only.
    // Guests are intentionally excluded here — they get no broad Firestore read.
    match /{document=**} {
      allow read, write: if isMember();
    }
  }
}
